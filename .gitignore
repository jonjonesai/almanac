# Secrets — NEVER commit
.env
.env.local
*.pem
*.key

# Renders and media assets (per-fire, can be regenerated)
*/renders/
*/assets/
*.mp4
*.mov
*.webm
*.wav
*.mp3
*.flac
*.jpg
*.jpeg
*.png

# But DO keep template + design imagery if any small reference files are added
!docs/**/*.png
!docs/**/*.jpg

# Skyfield ephemeris (16MB, auto-downloaded by skyfield on first run)
de421.bsp
*.bsp

# Build/composition artifacts
*/index.html
*/build_config.json
*/plan.json
*/words.json
*/beats.json

# Python
__pycache__/
*.pyc
*.pyo
