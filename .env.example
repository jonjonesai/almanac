# SP2 — Required environment variables
# Copy this file to `.env` and fill in your own keys. Never commit `.env`.

# ============================================================================
# CORE GENERATION (required for every fire)
# ============================================================================

# Anthropic — for script generation via `claude --print` CLI.
# Install the Claude Code CLI first: https://claude.com/claude-code
# Then `claude setup-token` for OAuth (preferred), or set an API key here.
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs — for text-to-speech narration.
# https://elevenlabs.io — Multilingual v2 model required.
ELEVENLABS_API_KEY=sk_...

# Replicate — for WhisperX word-level timestamps + MusicGen background music.
# https://replicate.com — pinned versions used:
#   victor-upmeet/whisperx@84d2ad2d...
#   meta/musicgen@671ac645...
REPLICATE_API_TOKEN=r8_...

# Freepik — for stock 9:16 vertical imagery (and video clips if a brand
# uses prefer_video_clips=true). Premium account recommended.
# https://www.freepik.com/api
FREEPIK_API_KEY=FPSX...

# ============================================================================
# DISTRIBUTION (only required if you publish from the pipeline; comment out
# for generation-only smoke tests)
# ============================================================================

# Cloudinary — for hosting the rendered mp4.
# https://cloudinary.com — used for storing + serving the final video.
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# Airtable — for the Social Queue topic feed (one base per brand).
# https://airtable.com — see brand.json for which base_id/table_id each brand reads.
AIRTABLE_API_KEY=pat...

# Metricool — for scheduling posts to TikTok / Instagram Reel / Facebook Reel / Pinterest Pin.
# https://metricool.com — `blog_id` per brand goes in brand.json.
METRICOOL_USER_TOKEN=...

# ============================================================================
# OPTIONAL RESEARCHER-ONLY KEYS
# ============================================================================

# NCBI E-utilities — used by oa_topic_researcher.py to query PubMed.
# Optional: increases rate limit from 3 req/sec to 10 req/sec.
# https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=
